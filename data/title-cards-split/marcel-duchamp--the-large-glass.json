    {
      "id": "spring-necktie-split-card",
      "term": "spring necktie",
      "scope": "global",
      "title": "Spring / Necktie",
      "description": "The circular necktie from Duchamp's Chocolate Grinder connects to his 1911 painting 'Young Man and Girl in Spring.' The necktie's circular form appears in both works, linking the mechanical bachelor apparatus to the pastoral romance - an early cipher in Duchamp's systematic exploration of desire, mechanics, and the bride-bachelor relationship.",
      "section": "Marcel Duchamp",
      "category": "The Large Glass",
      "subcategory": "Components",
      "isSplit": true,
      "images": [
        "http://www.toutfait.com/images/articles/godwin/image001.jpg",
        "https://iiif.duchamparchives.org/image/iiif/2/1950-134-69-pma/square/!240,240/0/default.jpg"
      ],
      "links": [
        {
          "label": "Spring, 1911 - Toutfait Analysis",
          "url": "https://www.toutfait.com/marcel-duchamp-spring-1911-where-it-all-begins/"
        },
        {
          "label": "Chocolate Grinder (No. 1) - Duchamp Archives",
          "url": "https://www.duchamparchives.org/pma/object/51518/"
        }
      ],
